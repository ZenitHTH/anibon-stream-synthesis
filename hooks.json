{
  "anibon-byte-guard": {
    "PreToolUse": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "type": "command",
            "command": "python3 skills/anibon-timestamper/scripts/check_sections.py --file \"$TARGET_FILE\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
